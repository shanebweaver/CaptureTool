<?xml version="1.0" encoding="utf-8" ?>
<local:VideoEditPageBase
    x:Class="CaptureTool.Presentation.Windows.WinUI.Xaml.Pages.VideoEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:videoedit="using:CaptureTool.Presentation.Features.VideoEdit"
    d:DataContext="{d:DesignInstance Type=videoedit:VideoEditPageViewModel}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Toolbar  -->
        <CommandBar DefaultLabelPosition="Right" IsOpen="False">
            <!--  Trim  -->
            <AppBarToggleButton
                x:Uid="VideoEdit_TrimButton"
                Command="{x:Bind ViewModel.ToggleTrimModeCommand}"
                Icon="Trim"
                IsChecked="{x:Bind ViewModel.IsInTrimMode, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.IsVideoReady, Mode=OneWay}" />

            <AppBarSeparator />

            <!--  Copy  -->
            <AppBarButton
                x:Uid="VideoEdit_CopyButton"
                Command="{x:Bind ViewModel.CopyCommand}"
                Icon="Copy"
                IsEnabled="{x:Bind ViewModel.IsVideoReady, Mode=OneWay}">
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="C" Modifiers="Control" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>

            <!--  Save  -->
            <AppBarButton
                x:Uid="VideoEdit_SaveButton"
                Command="{x:Bind ViewModel.SaveCommand}"
                Icon="Save"
                IsEnabled="{x:Bind ViewModel.IsVideoReady, Mode=OneWay}">
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="S" Modifiers="Control" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
        </CommandBar>

        <!--  Content  -->
        <Grid Grid.Row="1" Padding="8,0,8,8">
            <MediaPlayerElement
                x:Name="OriginalVideoPlayer"
                AreTransportControlsEnabled="{x:Bind ViewModel.AreTransportControlsVisible, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsVideoReady, Mode=OneWay}" />
            <MediaPlayerElement
                x:Name="RenderedTrimVideoPlayer"
                AreTransportControlsEnabled="{x:Bind ViewModel.AreTransportControlsVisible, Mode=OneWay}"
                Visibility="Collapsed" />

            <Grid
                x:Name="TrimPreviewLoadingOverlay"
                Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                Visibility="Collapsed">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
                    <ProgressRing
                        Width="48"
                        Height="48"
                        IsActive="True" />
                    <TextBlock
                        x:Uid="VideoEdit_RenderingTrimPreviewText"
                        HorizontalAlignment="Center"
                        FontSize="16"
                        Opacity="0.7"
                        Text="Preparing preview..." />
                </StackPanel>
            </Grid>

            <!--  Loading indicator for video finalization  -->
            <Grid Visibility="{x:Bind ViewModel.IsFinalizingVideo, Mode=OneWay}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
                    <ProgressRing
                        Width="48"
                        Height="48"
                        IsActive="True" />
                    <TextBlock
                        x:Uid="VideoEdit_FinalizingText"
                        HorizontalAlignment="Center"
                        FontSize="16"
                        Opacity="0.7"
                        Text="Finalizing video..." />
                </StackPanel>
            </Grid>
        </Grid>

        <Grid
            Grid.Row="2"
            BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{x:Bind ViewModel.IsInTrimMode, Mode=OneWay}">

            <Grid
                Grid.Row="2"
                MinHeight="96"
                MaxWidth="800"
                Padding="12,8"
                HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Uid="VideoEdit_TrimStartTimeText"
                        MinWidth="56"
                        FontSize="12"
                        Text="{x:Bind FormatTime(ViewModel.TrimStartSeconds), Mode=OneWay}" />
                    <TextBlock
                        x:Uid="VideoEdit_SelectedTrimDurationText"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Text="{x:Bind FormatTrimDuration(ViewModel.TrimStartSeconds, ViewModel.TrimEndSeconds), Mode=OneWay}" />
                    <TextBlock
                        x:Uid="VideoEdit_TrimEndTimeText"
                        Grid.Column="2"
                        MinWidth="56"
                        FontSize="12"
                        Text="{x:Bind FormatTime(ViewModel.TrimEndSeconds), Mode=OneWay}"
                        TextAlignment="Right" />
                </Grid>

                <Button
                    x:Name="TrimPreviewPlayButton"
                    x:Uid="VideoEdit_TrimPreviewPlayButton"
                    Grid.Row="1"
                    Grid.Column="0"
                    Width="40"
                    Height="40"
                    Margin="0,0,12,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    Click="TrimPreviewPlayButton_Click"
                    IsEnabled="{x:Bind ViewModel.IsVideoReady, Mode=OneWay}">
                    <FontIcon x:Name="TrimPreviewPlayIcon" Glyph="&#xE768;" />
                </Button>

                <Grid
                    Grid.Row="1"
                    Grid.Column="1"
                    ColumnSpacing="4">
                    <controls:VideoTrimRangeSlider
                        DurationSeconds="{x:Bind ViewModel.VideoDurationSeconds, Mode=OneWay}"
                        EndSeconds="{x:Bind ViewModel.TrimEndSeconds, Mode=OneWay}"
                        EndSecondsChanged="VideoTrimRangeSlider_EndSecondsChanged"
                        PlayheadSeconds="{x:Bind ViewModel.PlayheadSeconds, Mode=OneWay}"
                        PlayheadSecondsChanged="VideoTrimRangeSlider_PlayheadSecondsChanged"
                        StartSeconds="{x:Bind ViewModel.TrimStartSeconds, Mode=OneWay}"
                        StartSecondsChanged="VideoTrimRangeSlider_StartSecondsChanged" />
                </Grid>

                <TextBlock
                    x:Uid="VideoEdit_PlayheadTimeText"
                    Grid.Row="1"
                    Grid.Column="2"
                    MinWidth="56"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="{x:Bind FormatTime(ViewModel.PlayheadSeconds), Mode=OneWay}"
                    TextAlignment="Left" />
            </Grid>
        </Grid>
    </Grid>
</local:VideoEditPageBase>
