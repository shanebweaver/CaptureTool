<?xml version="1.0" encoding="utf-8" ?>
<local:ImageEditPageBase
    x:Class="CaptureTool.Presentation.Windows.WinUI.Xaml.Pages.ImageEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Controls"
    xmlns:converters="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:imageedit="using:CaptureTool.Presentation.Features.ImageEdit"
    xmlns:local="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=imageedit:ImageEditPageViewModel}"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:ShapeTypeToIntConverter x:Key="ShapeTypeToIntConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Toolbar  -->
        <CommandBar
            HorizontalAlignment="Center"
            DefaultLabelPosition="Right"
            IsOpen="False">
            <!--  Chroma Key  -->
            <AppBarToggleButton
                x:Uid="ImageEdit_ChromaKeyButton"
                Checked="ChromaKeyAppBarToggleButton_IsCheckedChanged"
                IsChecked="{x:Bind ViewModel.IsChromaKeyModeActive, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}"
                Unchecked="ChromaKeyAppBarToggleButton_IsCheckedChanged"
                Visibility="{x:Bind ViewModel.ChromaKeyTool.IsChromaKeyAddOnOwned, Mode=OneWay}">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="{StaticResource Color}" />
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>
            <AppBarSeparator Visibility="{x:Bind ViewModel.ChromaKeyTool.IsChromaKeyAddOnOwned, Mode=OneWay}" />
            <!--  Crop and orientation  -->
            <AppBarToggleButton
                x:Uid="ImageEdit_CropButton"
                Command="{x:Bind ViewModel.ToggleCropModeCommand}"
                Icon="Crop"
                IsChecked="{x:Bind ViewModel.IsCropModeActive, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}" />
            <AppBarToggleButton
                x:Uid="ImageEdit_ShapesButton"
                Command="{x:Bind ViewModel.ToggleShapesModeCommand}"
                IsChecked="{x:Bind ViewModel.IsShapesModeActive, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE91B;" />
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>
            <AppBarToggleButton
                x:Uid="ImageEdit_TextButton"
                Command="{x:Bind ViewModel.ToggleTextModeCommand}"
                IsChecked="{x:Bind ViewModel.IsTextModeActive, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE8D2;" />
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>
            <AppBarButton
                x:Uid="ImageEdit_RotateButton"
                Command="{x:Bind ViewModel.RotateCommand}"
                Icon="Rotate"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}" />
            <AppBarButton
                x:Uid="ImageEdit_FlipXButton"
                Command="{x:Bind ViewModel.FlipHorizontalCommand}"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}">
                <AppBarButton.Icon>
                    <FontIcon
                        FontFamily="{StaticResource FluentSystemIcons}"
                        FontSize="32"
                        Glyph="{StaticResource FlipHorizontal32Regular}" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                x:Uid="ImageEdit_FlipYButton"
                Command="{x:Bind ViewModel.FlipVerticalCommand}"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}">
                <AppBarButton.Icon>
                    <FontIcon
                        FontFamily="{StaticResource FluentSystemIcons}"
                        FontSize="32"
                        Glyph="{StaticResource FlipVertical32Regular}" />
                </AppBarButton.Icon>
            </AppBarButton>
            <!--  Undo/Redo  -->
            <AppBarSeparator />
            <AppBarButton
                x:Uid="ImageEdit_UndoButton"
                Command="{x:Bind ViewModel.UndoCommand}"
                Icon="Undo"
                IsEnabled="{x:Bind ViewModel.HasUndoStack, Mode=OneWay}" />
            <AppBarButton
                x:Uid="ImageEdit_RedoButton"
                Command="{x:Bind ViewModel.RedoCommand}"
                Icon="Redo"
                IsEnabled="{x:Bind ViewModel.HasRedoStack, Mode=OneWay}" />
            <!--  Export  -->
            <AppBarSeparator />
            <!--  Copy  -->
            <AppBarButton
                x:Uid="ImageEdit_CopyButton"
                Command="{x:Bind ViewModel.CopyCommand}"
                Icon="Copy"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}">
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="C" Modifiers="Control" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <!--  Save  -->
            <AppBarButton
                x:Uid="ImageEdit_SaveButton"
                Command="{x:Bind ViewModel.SaveCommand}"
                Icon="Save"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}">
                <AppBarButton.Label>Save as</AppBarButton.Label>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="S" Modifiers="Control" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <!--  Print  -->
            <AppBarButton
                x:Uid="ImageEdit_PrintButton"
                Command="{x:Bind ViewModel.PrintCommand}"
                Icon="Print"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}">
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="P" Modifiers="Control" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <!--  Share  -->
            <AppBarButton
                x:Uid="ImageEdit_ShareButton"
                Command="{x:Bind ViewModel.ShareCommand}"
                Icon="Share"
                IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}" />
        </CommandBar>

        <!--  Canvas  -->
        <Grid
            x:Name="CanvasContainer"
            Background="{ThemeResource ImageEditCanvasBackgroundBrush}"
            BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
            BorderThickness="0,1"
            Row="2">
            <controls:ImageCanvas
                x:Name="ImageCanvas"
                CanvasSize="{x:Bind ViewModel.ImageSize, Mode=OneWay}"
                CropRect="{x:Bind ViewModel.CropRect, Mode=OneWay}"
                CropRectChanged="ImageCanvas_CropRectChanged"
                Drawables="{x:Bind ViewModel.Drawables, Mode=OneWay}"
                InteractionComplete="ImageCanvas_InteractionComplete"
                IsAutoZoomLocked="{x:Bind ViewModel.IsAutoZoomLocked, Mode=OneWay}"
                IsCropModeEnabled="{x:Bind ViewModel.IsCropModeActive, Mode=OneWay}"
                IsShapesModeEnabled="{x:Bind ViewModel.IsShapesModeActive, Mode=OneWay}"
                IsTextModeEnabled="{x:Bind ViewModel.IsTextModeActive, Mode=OneWay}"
                Orientation="{x:Bind ViewModel.Orientation, Mode=OneWay}"
                SelectedShapeType="{x:Bind ViewModel.ShapeTool.SelectedShapeType, Mode=OneWay}"
                ShapeDeleted="ImageCanvas_ShapeDeleted"
                ShapeDrawn="ImageCanvas_ShapeDrawn"
                ShapeDrawableSelected="ImageCanvas_ShapeDrawableSelected"
                ShapeFillColor="{x:Bind ViewModel.ShapeTool.ShapeFillColor, Mode=OneWay}"
                ShapeModified="ImageCanvas_ShapeModified"
                ShapeStrokeColor="{x:Bind ViewModel.ShapeTool.ShapeStrokeColor, Mode=OneWay}"
                ShapeStrokeWidth="{x:Bind ViewModel.ShapeTool.ShapeStrokeWidth, Mode=OneWay}"
                TextBackgroundColor="{x:Bind ViewModel.TextTool.TextBackgroundColor, Mode=OneWay}"
                TextBoxDrawn="ImageCanvas_TextBoxDrawn"
                TextDrawableSelected="ImageCanvas_TextDrawableSelected"
                TextFontFamily="{x:Bind ViewModel.TextTool.TextFontFamily, Mode=OneWay}"
                TextFontSize="{x:Bind ViewModel.TextTool.TextFontSize, Mode=OneWay}"
                TextForegroundColor="{x:Bind ViewModel.TextTool.TextFontColor, Mode=OneWay}" />

            <Grid
                x:Name="FloatingToolbarLayer"
                Margin="12,8,12,0"
                HorizontalAlignment="stretch"
                VerticalAlignment="Top">
                <!--  Chroma key options  -->
                <controls:ChromaKeyToolbar
                    x:Name="ChromaKeyToolbarHost"
                    HorizontalAlignment="Center"
                    ChromaKeyInteractionCompleted="ChromaKeyToolbar_ChromaKeyInteractionCompleted"
                    ChromaKeyInteractionStarted="ChromaKeyToolbar_ChromaKeyInteractionStarted"
                    ColorOptions="{x:Bind ViewModel.ChromaKeyTool.ChromaKeyColorOptions, Mode=OneWay}"
                    Desaturation="{x:Bind ViewModel.ChromaKeyTool.ChromaKeyDesaturation, Mode=OneWay}"
                    DesaturationChanged="ChromaKeyToolbar_DesaturationChanged"
                    Opacity="0"
                    SelectedColorOptionIndex="{x:Bind ViewModel.ChromaKeyTool.SelectedChromaKeyColorOption, Mode=OneWay}"
                    SelectedColorOptionIndexChanged="ChromaKeyToolbar_SelectedColorOptionIndexChanged"
                    Tolerance="{x:Bind ViewModel.ChromaKeyTool.ChromaKeyTolerance, Mode=OneWay}"
                    ToleranceChanged="ChromaKeyToolbar_ToleranceChanged"
                    Visibility="Collapsed">
                    <controls:ChromaKeyToolbar.RenderTransform>
                        <TranslateTransform Y="-8" />
                    </controls:ChromaKeyToolbar.RenderTransform>
                </controls:ChromaKeyToolbar>

                <!--  Shapes options  -->
                <controls:ShapeToolbar
                    x:Name="ShapeToolbarHost"
                    HorizontalAlignment="Center"
                    FillColor="{x:Bind ViewModel.ShapeTool.ShapeFillColor, Mode=OneWay}"
                    FillColorChanged="ShapeToolbar_FillColorChanged"
                    FillColorOptions="{x:Bind ViewModel.ShapeTool.ShapeFillColorOptions, Mode=OneWay}"
                    FillOpacity="{x:Bind ViewModel.ShapeTool.ShapeFillOpacity, Mode=OneWay}"
                    FillOpacityChanged="ShapeToolbar_FillOpacityChanged"
                    Opacity="0"
                    SelectedShapeTypeIndex="{x:Bind ViewModel.ShapeTool.SelectedShapeType, Mode=OneWay, Converter={StaticResource ShapeTypeToIntConverter}}"
                    SelectedShapeTypeIndexChanged="ShapeToolbar_SelectedShapeTypeIndexChanged"
                    StrokeColor="{x:Bind ViewModel.ShapeTool.ShapeStrokeColor, Mode=OneWay}"
                    StrokeColorChanged="ShapeToolbar_StrokeColorChanged"
                    StrokeColorOptions="{x:Bind ViewModel.ShapeTool.ShapeStrokeColorOptions, Mode=OneWay}"
                    StrokeOpacity="{x:Bind ViewModel.ShapeTool.ShapeStrokeOpacity, Mode=OneWay}"
                    StrokeOpacityChanged="ShapeToolbar_StrokeOpacityChanged"
                    StrokeWidth="{x:Bind ViewModel.ShapeTool.ShapeStrokeWidth, Mode=OneWay}"
                    StrokeWidthChanged="ShapeToolbar_StrokeWidthChanged"
                    StyleInteractionCompleted="Toolbar_StyleInteractionCompleted"
                    StyleInteractionStarted="Toolbar_StyleInteractionStarted"
                    Visibility="Collapsed">
                    <controls:ShapeToolbar.RenderTransform>
                        <TranslateTransform Y="-8" />
                    </controls:ShapeToolbar.RenderTransform>
                </controls:ShapeToolbar>

                <!--  Text options  -->
                <controls:TextToolbar
                    x:Name="TextToolbarHost"
                    HorizontalAlignment="Center"
                    Opacity="0"
                    StyleInteractionCompleted="Toolbar_StyleInteractionCompleted"
                    StyleInteractionStarted="Toolbar_StyleInteractionStarted"
                    TextBackgroundColor="{x:Bind ViewModel.TextTool.TextBackgroundColor, Mode=OneWay}"
                    TextBackgroundColorChanged="TextToolbar_BackgroundColorChanged"
                    TextBackgroundColorOpacity="{x:Bind ViewModel.TextTool.TextBackgroundColorOpacity, Mode=OneWay}"
                    TextBackgroundColorOpacityChanged="TextToolbar_BackgroundColorOpacityChanged"
                    TextBackgroundColorOptions="{x:Bind ViewModel.TextTool.TextBackgroundColorOptions, Mode=OneWay}"
                    TextFontColor="{x:Bind ViewModel.TextTool.TextFontColor, Mode=OneWay}"
                    TextFontColorChanged="TextToolbar_FontColorChanged"
                    TextFontColorOpacity="{x:Bind ViewModel.TextTool.TextFontColorOpacity, Mode=OneWay}"
                    TextFontColorOpacityChanged="TextToolbar_FontColorOpacityChanged"
                    TextFontColorOptions="{x:Bind ViewModel.TextTool.TextFontColorOptions, Mode=OneWay}"
                    TextFontFamily="{x:Bind ViewModel.TextTool.TextFontFamily, Mode=OneWay}"
                    TextFontFamilyChanged="TextToolbar_FontFamilyChanged"
                    TextFontSize="{x:Bind ViewModel.TextTool.TextFontSize, Mode=OneWay}"
                    TextFontSizeChanged="TextToolbar_FontSizeChanged"
                    Visibility="Collapsed">
                    <controls:TextToolbar.RenderTransform>
                        <TranslateTransform Y="-8" />
                    </controls:TextToolbar.RenderTransform>
                </controls:TextToolbar>
            </Grid>
        </Grid>

        <ProgressRing
            Grid.Row="2"
            Width="48"
            Height="48"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="True"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <Grid
            MinHeight="38"
            Padding="8"
            Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                x:Name="InfoPanel"
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <TextBlock
                    x:Name="DimensionsTextBlock"
                    x:Uid="ImageEdit_Info_Dimensions"
                    MinWidth="72"
                    FontSize="12"
                    FontWeight="SemiLight"
                    TextAlignment="Right">
                    <Run Text="{x:Bind ViewModel.CropRect.Width, Mode=OneWay}" />
                    <Run Text="×" />
                    <Run Text="{x:Bind ViewModel.CropRect.Height, Mode=OneWay}" /><Run Text="px" />
                </TextBlock>
                <TextBlock
                    x:Name="OffsetTextBlock"
                    x:Uid="ImageEdit_Info_Offset"
                    MinWidth="72"
                    FontSize="12"
                    FontWeight="SemiLight"
                    TextAlignment="Right">
                    <Run Text="(" /><Run Text="{x:Bind ViewModel.CropRect.Left, Mode=OneWay}" /><Run Text="," />
                    <Run Text="{x:Bind ViewModel.CropRect.Top, Mode=OneWay}" /><Run Text=")" /><Run Text="px" />
                </TextBlock>
                <TextBlock
                    x:Name="RotationTextBlock"
                    x:Uid="ImageEdit_Info_Rotation"
                    MinWidth="36"
                    FontSize="12"
                    FontWeight="SemiLight"
                    Text="{x:Bind ViewModel.RotationDisplayName, Mode=OneWay}"
                    TextAlignment="Right" />
                <TextBlock
                    x:Name="MirroredTextBlock"
                    x:Uid="ImageEdit_Info_Mirrored"
                    MinWidth="72"
                    FontSize="12"
                    FontWeight="SemiLight"
                    Text="{x:Bind ViewModel.MirroredDisplayName, Mode=OneWay}"
                    TextAlignment="Right" />
            </StackPanel>

            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <ToggleButton
                    x:Name="AutoZoomLockToggle"
                    x:Uid="ImageEdit_AutoZoomLockButton"
                    MinWidth="32"
                    Padding="8,4"
                    Checked="AutoZoomLockToggle_IsCheckedChanged"
                    IsChecked="{x:Bind ViewModel.IsAutoZoomLocked, Mode=OneWay}"
                    IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}"
                    Unchecked="AutoZoomLockToggle_IsCheckedChanged">
                    <FontIcon FontSize="16" Glyph="&#xE72E;" />
                </ToggleButton>
                <Button
                    x:Uid="ImageEdit_ZoomAndCenterButton"
                    MinWidth="32"
                    Padding="8,4"
                    Command="{x:Bind ViewModel.ZoomAndCenterCommand}"
                    IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}">
                    <FontIcon FontSize="16" Glyph="&#xE71E;" />
                </Button>
                <TextBlock
                    x:Uid="ImageEdit_ZoomLabel"
                    VerticalAlignment="Center"
                    FontSize="12" />
                <Slider
                    x:Name="ZoomSlider"
                    Width="120"
                    VerticalAlignment="Center"
                    IsEnabled="{x:Bind ViewModel.IsLoaded, Mode=OneWay}"
                    Maximum="200"
                    Minimum="1"
                    StepFrequency="1"
                    ValueChanged="ZoomSlider_ValueChanged"
                    Value="{x:Bind ViewModel.ZoomPercentage, Mode=OneWay}" />
                <TextBlock
                    MinWidth="32"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="{x:Bind FormatZoomPercentage(ViewModel.ZoomPercentage), Mode=OneWay}"
                    TextAlignment="Right" />
            </StackPanel>
        </Grid>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="CommonStates">
                <!--  Minimal: Show only dimensions (smallest screens)  -->
                <VisualState x:Name="MinimalState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="DimensionsTextBlock.Visibility" Value="Visible" />
                        <Setter Target="OffsetTextBlock.Visibility" Value="Collapsed" />
                        <Setter Target="RotationTextBlock.Visibility" Value="Collapsed" />
                        <Setter Target="MirroredTextBlock.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                <!--  Narrow: Show Dimensions and Offset  -->
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="550" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="DimensionsTextBlock.Visibility" Value="Visible" />
                        <Setter Target="OffsetTextBlock.Visibility" Value="Visible" />
                        <Setter Target="RotationTextBlock.Visibility" Value="Collapsed" />
                        <Setter Target="MirroredTextBlock.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                <!--  Medium: Show Dimensions, Offset, and Rotation  -->
                <VisualState x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="600" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="DimensionsTextBlock.Visibility" Value="Visible" />
                        <Setter Target="OffsetTextBlock.Visibility" Value="Visible" />
                        <Setter Target="RotationTextBlock.Visibility" Value="Visible" />
                        <Setter Target="MirroredTextBlock.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                <!--  Wide: Show all info  -->
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="650" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="DimensionsTextBlock.Visibility" Value="Visible" />
                        <Setter Target="OffsetTextBlock.Visibility" Value="Visible" />
                        <Setter Target="RotationTextBlock.Visibility" Value="Visible" />
                        <Setter Target="MirroredTextBlock.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</local:ImageEditPageBase>
