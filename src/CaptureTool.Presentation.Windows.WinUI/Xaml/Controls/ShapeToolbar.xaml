<?xml version="1.0" encoding="utf-8" ?>
<local:UserControlBase
    x:Class="CaptureTool.Presentation.Windows.WinUI.Xaml.Controls.ShapeToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:ShapeToolbar}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:ColorTypeConverter x:Key="ColorTypeConverter" />
    </UserControl.Resources>

    <Grid>
        <StackPanel Orientation="Horizontal" Spacing="12">
            <!--  Shape Type  -->
            <ComboBox
                x:Name="ShapeTypeComboBox"
                x:Uid="ShapeToolbar_ShapeType"
                Width="120"
                SelectedIndex="{x:Bind SelectedShapeTypeIndex, Mode=OneWay}"
                SelectionChanged="ShapeTypeComboBox_SelectionChanged">
                <ComboBoxItem x:Uid="ShapeToolbar_RectangleItem" Tag="0" />
                <ComboBoxItem x:Uid="ShapeToolbar_EllipseItem" Tag="1" />
                <ComboBoxItem x:Uid="ShapeToolbar_LineItem" Tag="2" />
                <ComboBoxItem x:Uid="ShapeToolbar_ArrowItem" Tag="3" />
            </ComboBox>

            <!--  Stroke Color  -->
            <StackPanel Spacing="8">
                <TextBlock x:Uid="ShapeToolbar_StrokeColor" />
                <Button
                    x:Name="StrokeColorButton"
                    MinWidth="68"
                    Padding="8,4">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="24"
                            Height="24"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Rectangle RadiusX="3" RadiusY="3">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="{x:Bind StrokeColor, Mode=OneWay, Converter={StaticResource ColorTypeConverter}}" />
                                </Rectangle.Fill>
                            </Rectangle>
                        </Border>
                        <FontIcon
                            Grid.Column="1"
                            FontSize="12"
                            Glyph="&#xE70D;" />
                    </Grid>
                    <Button.Flyout>
                        <Flyout>
                            <local:ColorPalettePicker
                                ColorOptions="{x:Bind StrokeColorOptions, Mode=OneWay}"
                                MaximumRowsOrColumns="6"
                                SelectedColor="{x:Bind StrokeColor, Mode=OneWay}"
                                SelectedColorChanged="StrokeColorPalette_SelectedColorChanged" />
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <!--  Fill Color  -->
            <StackPanel Spacing="8">
                <TextBlock x:Uid="ShapeToolbar_FillColor" />
                <Button
                    x:Name="FillColorButton"
                    MinWidth="68"
                    Padding="8,4">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="24"
                            Height="24"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Rectangle RadiusX="3" RadiusY="3">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="{x:Bind FillColor, Mode=OneWay, Converter={StaticResource ColorTypeConverter}}" />
                                </Rectangle.Fill>
                            </Rectangle>
                        </Border>
                        <FontIcon
                            Grid.Column="1"
                            FontSize="12"
                            Glyph="&#xE70D;" />
                    </Grid>
                    <Button.Flyout>
                        <Flyout>
                            <local:ColorPalettePicker
                                ColorOptions="{x:Bind FillColorOptions, Mode=OneWay}"
                                MaximumRowsOrColumns="6"
                                SelectedColor="{x:Bind FillColor, Mode=OneWay}"
                                SelectedColorChanged="FillColorPalette_SelectedColorChanged" />
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <!--  Stroke Width  -->
            <StackPanel Spacing="8">
                <TextBlock x:Uid="ShapeToolbar_StrokeWidth" />
                <NumberBox
                    x:Name="StrokeWidthNumberBox"
                    LargeChange="1"
                    Maximum="20"
                    Minimum="1"
                    SmallChange="1"
                    SpinButtonPlacementMode="Inline"
                    ValueChanged="StrokeWidthNumberBox_ValueChanged"
                    Value="{x:Bind StrokeWidth, Mode=OneWay}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</local:UserControlBase>
