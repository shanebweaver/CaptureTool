<?xml version="1.0" encoding="utf-8" ?>
<local:UserControlBase
    x:Class="CaptureTool.Presentation.Windows.WinUI.Xaml.Controls.ShapeToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:ShapeToolbar}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:ColorTypeConverter x:Key="ColorTypeConverter" />
        <Style x:Key="ColorPaletteFlyoutPresenterStyle" TargetType="FlyoutPresenter">
            <Setter Property="Background" Value="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" />
        </Style>
        <Style x:Key="ShapeTypeComboBoxIconStyle" TargetType="Shape">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Stroke" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="StrokeThickness" Value="1.6" />
        </Style>
        <Style x:Key="ShapeTypeComboBoxLineIconStyle" TargetType="Line">
            <Setter Property="Stroke" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="StrokeThickness" Value="1.8" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
        </Style>
    </UserControl.Resources>

    <Border
        Padding="8,6"
        Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
        BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <StackPanel Orientation="Horizontal" Spacing="4">
            <!--  Shape Type  -->
            <ComboBox
                x:Name="ShapeTypeComboBox"
                x:Uid="ShapeToolbar_ShapeTypeComboBox"
                MinWidth="140"
                MinHeight="34"
                AutomationProperties.Name="Shape type"
                Background="Transparent"
                BorderBrush="Transparent"
                SelectedIndex="{x:Bind SelectedShapeTypeIndex, Mode=OneWay}"
                SelectionChanged="ShapeTypeComboBox_SelectionChanged"
                ToolTipService.ToolTip="Choose shape type">
                <ComboBoxItem
                    x:Uid="ShapeToolbar_RectangleOption"
                    Tag="0"
                    ToolTipService.ToolTip="Rectangle shape">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Rectangle Style="{StaticResource ShapeTypeComboBoxIconStyle}" />
                        <TextBlock x:Uid="ShapeToolbar_RectangleItem" Text="Rectangle" />
                    </StackPanel>
                </ComboBoxItem>
                <ComboBoxItem
                    x:Uid="ShapeToolbar_EllipseOption"
                    Tag="1"
                    ToolTipService.ToolTip="Ellipse shape">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Style="{StaticResource ShapeTypeComboBoxIconStyle}" />
                        <TextBlock x:Uid="ShapeToolbar_EllipseItem" Text="Ellipse" />
                    </StackPanel>
                </ComboBoxItem>
                <ComboBoxItem
                    x:Uid="ShapeToolbar_LineOption"
                    Tag="2"
                    ToolTipService.ToolTip="Line shape">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Line
                            Style="{StaticResource ShapeTypeComboBoxLineIconStyle}"
                            X1="1"
                            X2="15"
                            Y1="15"
                            Y2="1" />
                        <TextBlock x:Uid="ShapeToolbar_LineItem" Text="Line" />
                    </StackPanel>
                </ComboBoxItem>
                <ComboBoxItem
                    x:Uid="ShapeToolbar_ArrowOption"
                    Tag="3"
                    ToolTipService.ToolTip="Arrow shape">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Grid Width="16" Height="16">
                            <Line
                                Style="{StaticResource ShapeTypeComboBoxLineIconStyle}"
                                X1="1"
                                X2="14"
                                Y1="14"
                                Y2="1" />
                            <Polyline
                                Points="8,1 14,1 14,7"
                                Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                StrokeEndLineCap="Round"
                                StrokeLineJoin="Round"
                                StrokeStartLineCap="Round"
                                StrokeThickness="1.8" />
                        </Grid>
                        <TextBlock x:Uid="ShapeToolbar_ArrowItem" Text="Arrow" />
                    </StackPanel>
                </ComboBoxItem>
            </ComboBox>

            <!--  Stroke Color  -->
            <Button
                x:Name="StrokeColorButton"
                x:Uid="ShapeToolbar_StrokeColorButton"
                MinWidth="68"
                MinHeight="34"
                Padding="8,4"
                Background="Transparent"
                BorderBrush="Transparent">
                <Grid VerticalAlignment="Center" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Rectangle RadiusX="3" RadiusY="3">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{x:Bind StrokeColor, Mode=OneWay, Converter={StaticResource ColorTypeConverter}}" />
                            </Rectangle.Fill>
                        </Rectangle>
                    </Border>
                    <TextBlock
                        x:Uid="ShapeToolbar_StrokeColorButtonLabel"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Text="Outline" />
                    <FontIcon
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Glyph="&#xE70D;" />
                </Grid>
                <Button.Flyout>
                    <Flyout FlyoutPresenterStyle="{StaticResource ColorPaletteFlyoutPresenterStyle}">
                        <local:ColorPalettePicker
                            ColorOptions="{x:Bind StrokeColorOptions, Mode=OneWay}"
                            IsThicknessVisible="True"
                            MaximumRowsOrColumns="4"
                            OpacityPercentage="{x:Bind StrokeOpacity, Mode=OneWay}"
                            OpacityPercentageChanged="StrokeColorPalette_OpacityPercentageChanged"
                            SelectedColor="{x:Bind StrokeColor, Mode=OneWay}"
                            SelectedColorChanged="StrokeColorPalette_SelectedColorChanged"
                            SliderInteractionCompleted="ColorPalette_SliderInteractionCompleted"
                            SliderInteractionStarted="ColorPalette_SliderInteractionStarted"
                            Thickness="{x:Bind StrokeWidth, Mode=OneWay}"
                            ThicknessChanged="StrokeColorPalette_ThicknessChanged" />
                    </Flyout>
                </Button.Flyout>
            </Button>

            <!--  Fill Color  -->
            <Button
                x:Name="FillColorButton"
                x:Uid="ShapeToolbar_FillColorButton"
                MinWidth="68"
                MinHeight="34"
                Padding="8,4"
                Background="Transparent"
                BorderBrush="Transparent"
                IsEnabled="{x:Bind IsFillColorEnabled, Mode=OneWay}">
                <Grid VerticalAlignment="Center" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Rectangle RadiusX="3" RadiusY="3">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{x:Bind FillColor, Mode=OneWay, Converter={StaticResource ColorTypeConverter}}" />
                            </Rectangle.Fill>
                        </Rectangle>
                    </Border>
                    <TextBlock
                        x:Uid="ShapeToolbar_FillColorButtonLabel"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Text="Fill" />
                    <FontIcon
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Glyph="&#xE70D;" />
                </Grid>
                <Button.Flyout>
                    <Flyout FlyoutPresenterStyle="{StaticResource ColorPaletteFlyoutPresenterStyle}">
                        <local:ColorPalettePicker
                            ColorOptions="{x:Bind FillColorOptions, Mode=OneWay}"
                            IsThicknessVisible="False"
                            MaximumRowsOrColumns="4"
                            OpacityPercentage="{x:Bind FillOpacity, Mode=OneWay}"
                            OpacityPercentageChanged="FillColorPalette_OpacityPercentageChanged"
                            SelectedColor="{x:Bind FillColor, Mode=OneWay}"
                            SelectedColorChanged="FillColorPalette_SelectedColorChanged"
                            SliderInteractionCompleted="ColorPalette_SliderInteractionCompleted"
                            SliderInteractionStarted="ColorPalette_SliderInteractionStarted" />
                    </Flyout>
                </Button.Flyout>
            </Button>
            </StackPanel>
        </Grid>
    </Border>
</local:UserControlBase>
