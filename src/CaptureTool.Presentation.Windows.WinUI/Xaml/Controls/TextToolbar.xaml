<?xml version="1.0" encoding="utf-8" ?>
<local:UserControlBase
    x:Class="CaptureTool.Presentation.Windows.WinUI.Xaml.Controls.TextToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:TextToolbar}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:ColorTypeConverter x:Key="ColorTypeConverter" />
    </UserControl.Resources>

    <Grid>
        <StackPanel Orientation="Horizontal" Spacing="12">
            <!--  Text Content  -->
            <StackPanel Spacing="4">
                <TextBlock x:Uid="TextToolbar_Content" />
                <TextBox
                    x:Name="TextContentBox"
                    Width="160"
                    MaxLength="500"
                    PlaceholderText="Enter text..."
                    Text="{x:Bind TextContent, Mode=OneWay}"
                    TextChanged="TextContentBox_TextChanged" />
            </StackPanel>

            <!--  Font Color  -->
            <StackPanel Spacing="4">
                <TextBlock x:Uid="TextToolbar_FontColor" />
                <ColorPicker
                    x:Name="FontColorPicker"
                    ColorSpectrumShape="Ring"
                    IsAlphaEnabled="False"
                    IsColorChannelTextInputVisible="False"
                    IsColorSliderVisible="True"
                    IsHexInputVisible="True"
                    Color="{x:Bind TextFontColor, Mode=OneWay, Converter={StaticResource ColorTypeConverter}}"
                    ColorChanged="FontColorPicker_ColorChanged" />
            </StackPanel>

            <!--  Font Family  -->
            <StackPanel Spacing="4">
                <TextBlock x:Uid="TextToolbar_FontFamily" />
                <TextBox
                    x:Name="FontFamilyBox"
                    Width="120"
                    Text="{x:Bind TextFontFamily, Mode=OneWay}"
                    TextChanged="FontFamilyBox_TextChanged" />
            </StackPanel>

            <!--  Font Size  -->
            <StackPanel Spacing="4">
                <TextBlock x:Uid="TextToolbar_FontSize" />
                <NumberBox
                    x:Name="FontSizeNumberBox"
                    Width="100"
                    LargeChange="4"
                    Maximum="200"
                    Minimum="8"
                    SmallChange="1"
                    SpinButtonPlacementMode="Inline"
                    Value="{x:Bind TextFontSize, Mode=OneWay}"
                    ValueChanged="FontSizeNumberBox_ValueChanged" />
            </StackPanel>
        </StackPanel>
    </Grid>
</local:UserControlBase>
