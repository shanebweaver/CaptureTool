<?xml version="1.0" encoding="utf-8" ?>
<controls:UserControlBase
    x:Class="CaptureTool.Presentation.Windows.WinUI.Xaml.Controls.CropOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=controls:CropOverlay}"
    mc:Ignorable="d">
    <Canvas x:Name="RootCanvas">
        <Grid
            x:Name="Boundary"
            Background="Transparent"
            BorderThickness="0">
            <Grid.BorderBrush>
                <SolidColorBrush Opacity=".5" Color="Black" />
            </Grid.BorderBrush>

            <!--  Border  -->
            <Rectangle
                Margin="-1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Stroke="White"
                StrokeThickness="1" />
        </Grid>

        <!--  Crop anchors  -->
        <Grid
            x:Name="AnchorBox_TopLeft"
            Width="40"
            Height="40"
            Background="Transparent"
            Visibility="{x:Bind CanResize, Mode=OneWay}">
            <ContentPresenter x:Name="Anchor_TopLeft" ContentTemplate="{x:Bind AnchorTopLeft, Mode=OneWay}" />
        </Grid>
        <Grid
            x:Name="AnchorBox_TopRight"
            Width="40"
            Height="40"
            Background="Transparent"
            Visibility="{x:Bind CanResize, Mode=OneWay}">
            <ContentPresenter x:Name="Anchor_TopRight" ContentTemplate="{x:Bind AnchorTopRight, Mode=OneWay}" />
        </Grid>
        <Grid
            x:Name="AnchorBox_BottomLeft"
            Width="40"
            Height="40"
            Background="Transparent"
            Visibility="{x:Bind CanResize, Mode=OneWay}">
            <ContentPresenter x:Name="Anchor_BottomLeft" ContentTemplate="{x:Bind AnchorBottomLeft, Mode=OneWay}" />
        </Grid>
        <Grid
            x:Name="AnchorBox_BottomRight"
            Width="40"
            Height="40"
            Background="Transparent"
            Visibility="{x:Bind CanResize, Mode=OneWay}">
            <ContentPresenter x:Name="Anchor_BottomRight" ContentTemplate="{x:Bind AnchorBottomRight, Mode=OneWay}" />
        </Grid>
        <Grid
            x:Name="AnchorBox_Top"
            Width="40"
            Height="40"
            Background="Transparent"
            Visibility="{x:Bind CanResize, Mode=OneWay}">
            <ContentPresenter x:Name="Anchor_Top" ContentTemplate="{x:Bind AnchorTop, Mode=OneWay}" />
        </Grid>
        <Grid
            x:Name="AnchorBox_Left"
            Width="40"
            Height="40"
            Background="Transparent"
            Visibility="{x:Bind CanResize, Mode=OneWay}">
            <ContentPresenter x:Name="Anchor_Left" ContentTemplate="{x:Bind AnchorLeft, Mode=OneWay}" />
        </Grid>
        <Grid
            x:Name="AnchorBox_Right"
            Width="40"
            Height="40"
            Background="Transparent"
            Visibility="{x:Bind CanResize, Mode=OneWay}">
            <ContentPresenter x:Name="Anchor_Right" ContentTemplate="{x:Bind AnchorRight, Mode=OneWay}" />
        </Grid>
        <Grid
            x:Name="AnchorBox_Bottom"
            Width="40"
            Height="40"
            Background="Transparent"
            Visibility="{x:Bind CanResize, Mode=OneWay}">
            <ContentPresenter x:Name="Anchor_Bottom" ContentTemplate="{x:Bind AnchorBottom, Mode=OneWay}" />
        </Grid>
    </Canvas>
</controls:UserControlBase>
