<?xml version="1.0" encoding="utf-8" ?>
<local:UserControlBase
    x:Class="CaptureTool.Presentation.Windows.WinUI.Xaml.Controls.AudioInputSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:audio="using:CaptureTool.Application.Abstractions.Audio"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="using:CaptureTool.Presentation.Windows.WinUI.Utils"
    d:DataContext="{d:DesignInstance Type=local:AudioInputSelector}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="AudioInputFlyoutPresenterStyle" TargetType="FlyoutPresenter">
            <Setter Property="Background" Value="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style x:Key="AudioInputListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <Grid
        Width="64"
        Height="32"
        ColumnSpacing="0"
        ToolTipService.ToolTip="{x:Bind SelectedAudioInputSource.DisplayName, Mode=OneWay}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="32" />
            <ColumnDefinition Width="32" />
        </Grid.ColumnDefinitions>

        <Button
            x:Name="MuteButton"
            Command="{x:Bind ToggleMuteCommand, Mode=OneWay}"
            IsEnabled="{x:Bind IsAvailable, Mode=OneWay}"
            Style="{StaticResource IconButtonStyle}">
            <Grid>
                <FontIcon
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    Glyph="{StaticResource Microphone}"
                    Visibility="{x:Bind utils:VisibilityUtility.InverseBoolToVisibility(IsMuted), Mode=OneWay}" />
                <FontIcon
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    Glyph="{StaticResource Cancel}"
                    Visibility="{x:Bind utils:VisibilityUtility.BoolToVisibility(IsMuted), Mode=OneWay}" />
            </Grid>
        </Button>

        <Button
            x:Name="AudioInputFlyoutButton"
            Grid.Column="1"
            IsEnabled="{x:Bind IsAvailable, Mode=OneWay}"
            Style="{StaticResource IconButtonStyle}">
            <FontIcon
                FontFamily="{StaticResource SymbolThemeFontFamily}"
                FontSize="12"
                Glyph="&#xE70D;" />
            <Button.Flyout>
                <Flyout FlyoutPresenterStyle="{StaticResource AudioInputFlyoutPresenterStyle}" Placement="Bottom">
                    <Grid
                        Width="300"
                        Height="190"
                        ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="58" />
                        </Grid.ColumnDefinitions>

                        <ListView
                            x:Name="AudioInputListView"
                            Height="190"
                            Padding="0"
                            Background="Transparent"
                            IsItemClickEnabled="True"
                            ItemContainerStyle="{StaticResource AudioInputListViewItemStyle}"
                            ItemsSource="{x:Bind AudioInputSources, Mode=OneWay}"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollMode="Enabled"
                            SelectedIndex="{x:Bind SelectedAudioInputSourceIndex, Mode=OneWay}"
                            SelectionChanged="AudioInputListView_SelectionChanged"
                            SelectionMode="Single"
                            SingleSelectionFollowsFocus="False">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="audio:AudioInputSource">
                                    <TextBlock
                                        MaxLines="1"
                                        Text="{x:Bind DisplayName}"
                                        TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid Grid.Column="1" Width="58">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <SymbolIcon
                                HorizontalAlignment="Center"
                                Symbol="Volume" />
                            <Slider
                                x:Name="VolumeSlider"
                                Grid.Row="1"
                                Height="130"
                                HorizontalAlignment="Center"
                                Maximum="100"
                                Minimum="0"
                                Orientation="Vertical"
                                StepFrequency="1"
                                TickFrequency="10"
                                Value="{x:Bind VolumePercentage, Mode=OneWay}"
                                ValueChanged="VolumeSlider_ValueChanged" />
                            <TextBlock
                                Grid.Row="2"
                                HorizontalAlignment="Center"
                                Text="{x:Bind FormatVolume(VolumePercentage), Mode=OneWay}"
                                TextAlignment="Center" />
                        </Grid>
                    </Grid>
                </Flyout>
            </Button.Flyout>
        </Button>
    </Grid>
</local:UserControlBase>
