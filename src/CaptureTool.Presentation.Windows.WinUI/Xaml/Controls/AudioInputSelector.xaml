<?xml version="1.0" encoding="utf-8" ?>
<local:UserControlBase
    x:Class="CaptureTool.Presentation.Windows.WinUI.Xaml.Controls.AudioInputSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:audio="using:CaptureTool.Application.Abstractions.Audio"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="using:CaptureTool.Presentation.Windows.WinUI.Utils"
    d:DataContext="{d:DesignInstance Type=local:AudioInputSelector}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="AudioInputFlyoutPresenterStyle" TargetType="FlyoutPresenter">
            <Setter Property="Background" Value="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style
            x:Key="AudioInputListViewItemStyle"
            BasedOn="{StaticResource DefaultListViewItemStyle}"
            TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <Grid
        Width="64"
        Height="32"
        ColumnSpacing="0"
        ToolTipService.ToolTip="{x:Bind GetToolTipText(IsAvailable, SelectedAudioInputSource), Mode=OneWay}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="32" />
            <ColumnDefinition Width="32" />
        </Grid.ColumnDefinitions>

        <Button
            x:Name="MuteButton"
            AutomationProperties.Name="{x:Bind GetMuteButtonText(IsMuted), Mode=OneWay}"
            Command="{x:Bind ToggleMuteCommand, Mode=OneWay}"
            IsEnabled="{x:Bind IsAvailable, Mode=OneWay}"
            Style="{StaticResource IconButtonStyle}"
            ToolTipService.ToolTip="{x:Bind GetMuteButtonText(IsMuted), Mode=OneWay}">
            <Grid>
                <FontIcon
                    FontFamily="{StaticResource FluentSystemIcons}"
                    Glyph="{StaticResource Mic20Regular}"
                    Visibility="{x:Bind utils:VisibilityUtility.InverseBoolToVisibility(IsMuted), Mode=OneWay}" />
                <FontIcon
                    FontFamily="{StaticResource FluentSystemIcons}"
                    Glyph="{StaticResource MicOff20Regular}"
                    Visibility="{x:Bind utils:VisibilityUtility.BoolToVisibility(IsMuted), Mode=OneWay}" />
            </Grid>
        </Button>

        <Button
            x:Name="AudioInputFlyoutButton"
            x:Uid="AudioInputSelector_InputFlyoutButton"
            Grid.Column="1"
            IsEnabled="{x:Bind IsAvailable, Mode=OneWay}"
            Style="{StaticResource IconButtonStyle}">
            <FontIcon
                FontFamily="{StaticResource SymbolThemeFontFamily}"
                FontSize="12"
                Glyph="&#xE70D;" />
            <Button.Flyout>
                <Flyout
                    FlyoutPresenterStyle="{StaticResource AudioInputFlyoutPresenterStyle}"
                    Placement="Bottom"
                    ShouldConstrainToRootBounds="False">
                    <Grid Width="300" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListView
                            x:Name="AudioInputListView"
                            x:Uid="AudioInputSelector_InputList"
                            Padding="0"
                            Background="Transparent"
                            IsItemClickEnabled="True"
                            ItemContainerStyle="{StaticResource AudioInputListViewItemStyle}"
                            ItemsSource="{x:Bind AudioInputSources, Mode=OneWay}"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollMode="Disabled"
                            SelectedIndex="{x:Bind SelectedAudioInputSourceIndex, Mode=OneWay}"
                            SelectionChanged="AudioInputListView_SelectionChanged"
                            SelectionMode="Single"
                            SingleSelectionFollowsFocus="False">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="audio:AudioInputSource">
                                    <TextBlock
                                        MaxLines="1"
                                        Text="{x:Bind DisplayName}"
                                        TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button
                            x:Uid="AudioInputSelector_ChangeDefaultSettingsButton"
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            Click="ChangeDefaultSettingsButton_Click">
                            <StackPanel
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <FontIcon
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="14"
                                    Glyph="{StaticResource Settings}" />
                                <TextBlock x:Uid="AudioInputSelector_ChangeDefaultSettingsButtonLabel" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Flyout>
            </Button.Flyout>
        </Button>
    </Grid>
</local:UserControlBase>
