<?xml version="1.0" encoding="utf-8" ?>
<local:UserControlBase
    x:Class="CaptureTool.Presentation.Windows.WinUI.Xaml.Controls.AudioInputSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:audio="using:CaptureTool.Application.Abstractions.Audio"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CaptureTool.Presentation.Windows.WinUI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="using:CaptureTool.Presentation.Windows.WinUI.Utils"
    d:DataContext="{d:DesignInstance Type=local:AudioInputSelector}"
    mc:Ignorable="d">
    <Grid ToolTipService.ToolTip="{x:Bind GetToolTipText(IsAvailable, SelectedAudioInputSource), Mode=OneWay}">
        <ToggleSplitButton
            x:Name="AudioInputToggleSplitButton"
            Width="64"
            Height="32"
            MinWidth="64"
            AutomationProperties.Name="{x:Bind GetMuteButtonText(IsMuted), Mode=OneWay}"
            Click="AudioInputToggleSplitButton_Click"
            IsChecked="{x:Bind IsMuted, Mode=OneWay}"
            IsEnabled="{x:Bind IsAvailable, Mode=OneWay}"
            ToolTipService.ToolTip="{x:Bind GetMuteButtonText(IsMuted), Mode=OneWay}">
            <ToggleSplitButton.Content>
                <Grid Width="20">
                    <FontIcon
                        FontFamily="{StaticResource FluentSystemIcons}"
                        Glyph="{StaticResource Mic20Regular}"
                        Visibility="{x:Bind utils:VisibilityUtility.InverseBoolToVisibility(IsMuted), Mode=OneWay}" />
                    <FontIcon
                        FontFamily="{StaticResource FluentSystemIcons}"
                        Glyph="{StaticResource MicOff20Regular}"
                        Visibility="{x:Bind utils:VisibilityUtility.BoolToVisibility(IsMuted), Mode=OneWay}" />
                </Grid>
            </ToggleSplitButton.Content>

            <ToggleSplitButton.Flyout>
                <Flyout Placement="Bottom" ShouldConstrainToRootBounds="False">
                    <Grid Width="300" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListView
                            x:Name="AudioInputListView"
                            x:Uid="AudioInputSelector_InputList"
                            Padding="0"
                            Background="Transparent"
                            IsItemClickEnabled="True"
                            ItemsSource="{x:Bind AudioInputSources, Mode=OneWay}"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollMode="Disabled"
                            SelectedIndex="{x:Bind SelectedAudioInputSourceIndex, Mode=OneWay}"
                            SelectionChanged="AudioInputListView_SelectionChanged"
                            SelectionMode="Single"
                            SingleSelectionFollowsFocus="False">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="audio:AudioInputSource">
                                    <TextBlock
                                        MaxLines="1"
                                        Text="{x:Bind DisplayName}"
                                        TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button
                            x:Uid="AudioInputSelector_ChangeDefaultSettingsButton"
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            Click="ChangeDefaultSettingsButton_Click">
                            <StackPanel
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <FontIcon
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="14"
                                    Glyph="{StaticResource Settings}" />
                                <TextBlock x:Uid="AudioInputSelector_ChangeDefaultSettingsButtonLabel" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Flyout>
            </ToggleSplitButton.Flyout>
        </ToggleSplitButton>
    </Grid>
</local:UserControlBase>
